# Hermes Home Server — шаблон переменных окружения
# install.ps1 создаёт .env из этого шаблона автоматически

# --- Telegram (обязательно) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- LLM провайдер OpenAI-compatible (обязательно) ---
OPENAI_BASE_URL=
OPENAI_API_KEY=

# --- Модель по умолчанию (заполняется install.ps1 по URL провайдера) ---
HERMES_MODEL=

# --- Идентификация установки (для status.ps1) ---
HERMES_PROVIDER_NAME=

# --- Резервное копирование ---
BACKUP_RETENTION=30
