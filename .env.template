# Hermes Home Server — шаблон переменных окружения
# install.ps1 создаёт .env из этого шаблона автоматически

# --- Telegram (обязательно) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- LLM провайдер OpenAI-compatible (обязательно) ---
OPENAI_BASE_URL=
OPENAI_API_KEY=

# --- Модель по умолчанию (заполняется install.ps1 по URL провайдера) ---
HERMES_MODEL=

# --- Идентификация установки (для status.ps1) ---
HERMES_PROVIDER_NAME=

# --- Резервное копирование ---
BACKUP_RETENTION=30
# пароль для шифрования .env внутри архива (пусто = без шифрования)
BACKUP_PASSWORD=
# зеркало архивов на другой диск / папку OneDrive (пусто = выключено)
# На хосте: New-HermesBackup копирует zip в этот путь.
# В контейнере (backup.sh): копирует только если путь существует внутри контейнера
# (Windows-путь вроде D:\Backups из контейнера недоступен — зеркало делает хост).
BACKUP_MIRROR_DIR=
